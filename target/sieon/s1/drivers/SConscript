import os
from building import *
Import('RTT_ROOT')

cwd = GetCurrentDir()

src = Glob('*.c')
if GetDepend('PKG_USING_CHERRYUSB'):
    src += Glob('drv_usbd/drv_usb_adapter.c')
else:
    src += Glob('usbd/*.c')

inc = [cwd]
if GetDepend('PKG_USING_CHERRYUSB'):
    inc += [cwd + '/drv_usbd']
else:
    inc += [cwd + '/usbd']

group = DefineGroup('PeripheralDriver', src, depend = [''], CPPPATH = inc)

Return('group')