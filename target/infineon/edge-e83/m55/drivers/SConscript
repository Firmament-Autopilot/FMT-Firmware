Import('RTT_ROOT')
Import('rtconfig')
from building import *

cwd = GetCurrentDir()

# add the general drivers.
src = Split("""
drv_common.c
""")

src += ['drv_gpio.c']
src += ['drv_uart.c']
src += ['drv_systick.c']
src += ['drv_i2c.c']
src += ['drv_spi.c']
src += ['drv_sdio.c']
src += ['drv_usbd_cdc.c']

if GetDepend('BSP_USING_ETH'):
	src += ['drv_eth.c']

path =  [cwd]
path += [cwd + '/config']

group = DefineGroup('Drivers', src, depend = [''], CPPPATH = path, LOCAL_CPPPATH = path)

Return('group')

