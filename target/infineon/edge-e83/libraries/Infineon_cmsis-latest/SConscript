from building import *
import rtconfig
Import('RTT_ROOT')

cwd = GetCurrentDir()

path = []
path += [cwd + '/Core/Include']
path += [cwd + '/Core/Include/m-profile']

if GetDepend('BSP_USING_CMSIS_DSP'):
    src = Glob('COMPONENT_CMSIS_DSP/Source/*/*.c')
    path += [cwd + '/COMPONENT_CMSIS_DSP/Include']
    path += [cwd + '/COMPONENT_CMSIS_DSP/PrivateInclude']
    group = DefineGroup('Libraries', src, depend=['BSP_USING_CMSIS_DSP'], CPPPATH=path)
else:
    group = DefineGroup('Libraries', [], depend=[''], CPPPATH=path)

Return('group')
